# Phase 7 crypto paper monitor and execution-readiness guardrails.
# This still does not connect to exchange accounts or place orders.

MARKET_TYPE=crypto_spot
DATA_SOURCE=ccxt
PAIRS=BTCUSDT,ETHUSDT

FORWARD_JOURNAL_LOG_PATH=logs/crypto_forward_journal.jsonl
FORWARD_OUTCOME_LOG_PATH=logs/crypto_forward_outcomes.jsonl
FORWARD_OUTCOME_SUMMARY_PATH=reports/crypto_forward_outcomes_summary.json
FORWARD_PERFORMANCE_REPORT_PATH=reports/crypto_forward_performance_report.json

PAPER_REPORT_JSON=reports/crypto_paper_trading_report.json
PAPER_LEDGER_CSV=reports/crypto_paper_trading_ledger.csv
PAPER_DASHBOARD_HTML=reports/crypto_paper_trading_dashboard.html
PAPER_STARTING_BALANCE=1000
PAPER_RISK_MODE=fixed
PAPER_RISK_PER_TRADE=25
PAPER_RISK_PCT=0.01
PAPER_ACCOUNT_CURRENCY=USD
PAPER_MAX_OPEN_POSITIONS=1
PAPER_MIN_SCORE=0

PHASE7_MONITOR_JSON=reports/crypto_phase7_paper_monitor.json
PHASE7_MONITOR_DASHBOARD_HTML=reports/crypto_phase7_paper_monitor_dashboard.html
PHASE7_MIN_PAPER_TRADES=30
PHASE7_MIN_SYMBOL_TRADES=5
PHASE7_MIN_AVG_R=0.10
PHASE7_MIN_PROFIT_FACTOR=1.20
PHASE7_MAX_DRAWDOWN_PCT=10.0
PHASE7_MIN_ROI_PCT=0.0
PHASE7_REQUIRED_SYMBOLS=BTCUSDT,ETHUSDT
PHASE7_REQUIRE_HEALTH_OK=1
PHASE7_REQUIRE_SIGNAL_LIVE_MODE_DISABLED=1

ENABLE_LIVE_MODE=0
ENABLE_LIVE_HEARTBEAT=1
LIVE_HEARTBEAT_PATH=logs/crypto_forward_heartbeat.json
HEALTH_MAX_SCAN_AGE_MINUTES=15
ENABLE_FEED_HEALTH_CHECKS=1
MARKET_DATA_DIAGNOSTICS_LOG_PATH=logs/crypto_forward_market_data.jsonl
