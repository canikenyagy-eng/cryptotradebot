# Phase 12 realtime feed + final pre-order guard.
# This layer can mark paper/testnet readiness only. It must not send orders.

PHASE12_PHASE11_REPORT_JSON=reports/crypto_phase11_market_safety_report.json
PHASE12_REALTIME_GUARD_JSON=reports/crypto_phase12_realtime_guard_report.json
PHASE12_REALTIME_GUARD_CSV=reports/crypto_phase12_realtime_guard_checks.csv
PHASE12_SNAPSHOT_JSON=logs/crypto_realtime_snapshots.json
PHASE12_MARKET_DATA_DIAGNOSTICS_JSONL=logs/crypto_forward_market_data.jsonl

PHASE12_SYMBOLS=BTCUSDT,ETHUSDT
PHASE12_EXCHANGE_ID=binance
PHASE12_DEFAULT_TYPE=spot
PHASE12_TIMEOUT_MS=10000
PHASE12_BINANCE_WEBSOCKET_URL=wss://stream.binance.com:9443

# Set this to 10-30 when you want to collect fresh websocket snapshots first.
PHASE12_COLLECT_WEBSOCKET_SECONDS=0
PHASE12_KEEP_COLLECTING_UNTIL_TIMEOUT=0

PHASE12_ALLOW_REST_FALLBACK=1
PHASE12_ENABLE_ORDER_BOOK_REFRESH=1
PHASE12_ORDER_BOOK_LIMIT=5

PHASE12_MAX_SNAPSHOT_AGE_SECONDS=10
PHASE12_MAX_SPREAD_BPS=10
PHASE12_MAX_ENTRY_PRICE_DEVIATION_BPS=50
PHASE12_MAX_EXCHANGE_TIME_DRIFT_MS=2000

PHASE12_REQUIRE_PHASE11_READY=1
PHASE12_REQUIRE_CLEAN_MARKET_DIAGNOSTICS=1
PHASE12_DIAGNOSTICS_TIMEFRAME=M5
PHASE12_MAX_MARKET_DIAGNOSTICS_AGE_SECONDS=900
