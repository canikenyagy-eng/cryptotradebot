# Phase 10 crypto testnet order request preview.
# This builds CCXT-style sandbox payloads only. It does not send exchange orders.

MARKET_TYPE=crypto_spot
DATA_SOURCE=ccxt
PAIRS=BTCUSDT,ETHUSDT
ENABLE_LIVE_MODE=0

PHASE10_PHASE9_REPORT_JSON=reports/crypto_phase9_sandbox_execution_report.json
PHASE10_PREVIEW_REPORT_JSON=reports/crypto_phase10_testnet_order_preview.json
PHASE10_REQUESTS_CSV=reports/crypto_phase10_testnet_order_requests.csv

PHASE10_EXCHANGE_ID=binance
PHASE10_DEFAULT_TYPE=spot
PHASE10_MAX_ORDERS_PER_RUN=5
PHASE10_ALLOWED_SYMBOLS=BTCUSDT,ETHUSDT
PHASE10_REQUIRE_PHASE9_READY=1
PHASE10_REQUIRE_SPOT_LONG_ONLY=1

# Intentionally unsupported in Phase 10.
PHASE10_TESTNET_SUBMISSION_ENABLED=0
PHASE10_ALLOW_LIVE_ORDERS=0
