# Phase 3 signal-only crypto validation profile.
# Use this for backtests and forward signal collection. Do not add exchange API keys here.

MARKET_TYPE=crypto_spot
DATA_SOURCE=ccxt
CCXT_EXCHANGE_ID=binance
CCXT_DEFAULT_TYPE=spot
CCXT_OHLCV_REQUEST_LIMIT=1000

PAIRS=BTCUSDT,ETHUSDT
SYMBOL_SPECS_JSON={"BTCUSDT":{"exchange_symbol":"BTC/USDT","tick_size":0.01,"min_order_size":0.00001,"maker_fee_rate":0.001,"taker_fee_rate":0.001},"ETHUSDT":{"exchange_symbol":"ETH/USDT","tick_size":0.01,"min_order_size":0.0001,"maker_fee_rate":0.001,"taker_fee_rate":0.001}}

ENABLE_PAIR_PROFILES=1
ALLOW_LIVE_PAIR_PROFILES=1
PAIR_PROFILES_BACKTEST_ONLY=1
PAIR_PROFILES_JSON={"BTCUSDT":{"min_score":78,"evaluation_step":20,"regime_blocklist":"EXPANSION,CONTRACTION,TREND"},"ETHUSDT":{"min_score":80,"evaluation_step":20,"regime_blocklist":"EXPANSION,CONTRACTION,TREND"}}

ENABLE_SESSION_GATE=0
SESSION_GATE_WINDOWS_UTC=
ENABLE_REGIME_LABEL_GATE=0
REGIME_LABEL_BLOCKLIST=
SMT_REFERENCE_MAP=

ENABLE_REALISTIC_EXECUTION=1
SPREAD_BY_PAIR=BTCUSDT:5,ETHUSDT:5
SLIPPAGE_MODE=volatility
MAX_SLIPPAGE_PIPS=10
LIMIT_TOUCH_TOLERANCE_PIPS=5
APPLY_SPREAD_TO_LIMIT=1

LTF_TIMEFRAME=M15
HTF_TIMEFRAME=H1
TRIGGER_TIMEFRAME=M5
HISTORY_LIMIT=1200
BACKTEST_EVALUATION_STEP=20
BACKTEST_ACCOUNT_ENABLED=1
BACKTEST_STARTING_BALANCE=1000
BACKTEST_RISK_PER_TRADE=50

ENABLE_LIVE_MODE=0
