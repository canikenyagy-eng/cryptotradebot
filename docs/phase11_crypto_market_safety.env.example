# Phase 11 real-time market safety.
# This checks public ticker/order-book/time data only. It does not send exchange orders.

MARKET_TYPE=crypto_spot
DATA_SOURCE=ccxt
PAIRS=BTCUSDT,ETHUSDT
ENABLE_LIVE_MODE=0

PHASE11_PHASE10_REPORT_JSON=reports/crypto_phase10_testnet_order_preview.json
PHASE11_MARKET_SAFETY_JSON=reports/crypto_phase11_market_safety_report.json
PHASE11_MARKET_SAFETY_CSV=reports/crypto_phase11_market_safety_checks.csv
PHASE11_MARKET_DATA_DIAGNOSTICS_JSONL=logs/crypto_forward_market_data.jsonl

PHASE11_EXCHANGE_ID=binance
PHASE11_DEFAULT_TYPE=spot
PHASE11_TIMEOUT_MS=10000
PHASE11_ENABLE_ORDER_BOOK_CHECK=1
PHASE11_ORDER_BOOK_LIMIT=5

PHASE11_MAX_TICKER_AGE_SECONDS=30
PHASE11_MAX_SPREAD_BPS=10
PHASE11_MAX_EXCHANGE_TIME_DRIFT_MS=2000
PHASE11_MAX_ENTRY_PRICE_DEVIATION_BPS=100

PHASE11_REQUIRE_PHASE10_READY=1
PHASE11_REQUIRE_CLEAN_MARKET_DIAGNOSTICS=1
PHASE11_DIAGNOSTICS_TIMEFRAME=M5
PHASE11_MAX_MARKET_DIAGNOSTICS_AGE_SECONDS=900

# Intentionally unsupported in Phase 11.
PHASE11_ALLOW_LIVE_ORDERS=0
