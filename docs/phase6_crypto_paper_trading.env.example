# Phase 6 crypto paper trading replay.
# This consumes Phase 4 journal + Phase 5 outcomes. It does not connect to exchange accounts or place orders.

MARKET_TYPE=crypto_spot
DATA_SOURCE=ccxt
PAIRS=BTCUSDT,ETHUSDT

FORWARD_JOURNAL_LOG_PATH=logs/crypto_forward_journal.jsonl
FORWARD_OUTCOME_LOG_PATH=logs/crypto_forward_outcomes.jsonl
FORWARD_PERFORMANCE_REPORT_PATH=reports/crypto_forward_performance_report.json

# CLI defaults for research.crypto_paper_trading_report:
# --starting-balance 1000
# --risk-mode fixed
# --risk-per-trade 25
# --risk-pct 0.01
# --account-currency USD
# --max-open-positions 1
# --sent-only

PAPER_REPORT_JSON=reports/crypto_paper_trading_report.json
PAPER_LEDGER_CSV=reports/crypto_paper_trading_ledger.csv
PAPER_DASHBOARD_HTML=reports/crypto_paper_trading_dashboard.html
PAPER_STARTING_BALANCE=1000
PAPER_RISK_MODE=fixed
PAPER_RISK_PER_TRADE=25
PAPER_RISK_PCT=0.01
PAPER_ACCOUNT_CURRENCY=USD
PAPER_MAX_OPEN_POSITIONS=1
PAPER_MIN_SCORE=0
