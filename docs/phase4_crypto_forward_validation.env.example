# Phase 4 crypto signal-only forward validation.
# Fill Telegram values if you want alerts. Do not add exchange API keys here.

TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
TELEGRAM_SEND_RETRIES=3
TELEGRAM_RETRY_BASE_DELAY_SECONDS=1.0

MARKET_TYPE=crypto_spot
DATA_SOURCE=ccxt
CCXT_EXCHANGE_ID=binance
CCXT_DEFAULT_TYPE=spot
CCXT_SANDBOX=0
CCXT_TIMEOUT_MS=10000
CCXT_ENABLE_RATE_LIMIT=1
CCXT_OHLCV_LIMIT=
CCXT_OHLCV_REQUEST_LIMIT=1000
CCXT_HEALTH_CHECK_SYMBOL=BTCUSDT
CCXT_TIMEFRAME_MAP_JSON=
CCXT_OHLCV_PARAMS_JSON=
CCXT_EXCHANGE_OPTIONS_JSON=

PAIRS=BTCUSDT,ETHUSDT
SYMBOL_SPECS_JSON={"BTCUSDT":{"exchange_symbol":"BTC/USDT","tick_size":0.01,"min_order_size":0.00001,"maker_fee_rate":0.001,"taker_fee_rate":0.001},"ETHUSDT":{"exchange_symbol":"ETH/USDT","tick_size":0.01,"min_order_size":0.0001,"maker_fee_rate":0.001,"taker_fee_rate":0.001}}

ENABLE_LIVE_MODE=0
ENABLE_PAIR_PROFILES=1
ALLOW_LIVE_PAIR_PROFILES=1
PAIR_PROFILES_BACKTEST_ONLY=1
PAIR_PROFILES_JSON={"BTCUSDT":{"min_score":78,"evaluation_step":20,"regime_blocklist":"EXPANSION,CONTRACTION,TREND","description":"Phase 3 strict range-only forward-validation profile."},"ETHUSDT":{"min_score":90,"evaluation_step":20,"regime_blocklist":"EXPANSION,CONTRACTION,TREND","allow_market_fallback":false,"description":"Phase 13 tightened ETH profile: score 90 and no MARKET fallback."}}

ENABLE_SESSION_GATE=0
SESSION_GATE_WINDOWS_UTC=
ENABLE_REGIME_LABEL_GATE=0
REGIME_LABEL_BLOCKLIST=
SMT_REFERENCE_MAP=

LTF_TIMEFRAME=M15
HTF_TIMEFRAME=H1
TRIGGER_TIMEFRAME=M5
HISTORY_LIMIT=1200
SCAN_INTERVAL_MINUTES=5

MARKET_DATA_CACHE_ENABLED=1
MARKET_DATA_CACHE_DIR=data/cache/ohlcv
MARKET_DATA_CACHE_TTL_HOURS=0.05
MARKET_DATA_CACHE_MODE=read_through
ENABLE_MARKET_DATA_FRESHNESS_GATE=1
MAX_LIVE_CANDLE_AGE_SECONDS=1800
ENABLE_MARKET_DATA_DIAGNOSTICS=1
MARKET_DATA_DIAGNOSTICS_LOG_PATH=logs/crypto_forward_market_data.jsonl
MARKET_DATA_DIAGNOSTICS_MAX_LATENCY_SECONDS=5.0
MARKET_DATA_DIAGNOSTICS_MAX_CANDLE_AGE_SECONDS=1800
MARKET_DATA_DIAGNOSTICS_LOG_CACHE_HITS=1

ENABLE_FORWARD_JOURNAL=1
FORWARD_JOURNAL_LOG_PATH=logs/crypto_forward_journal.jsonl
FORWARD_JOURNAL_INCLUDE_SCORE_BREAKDOWN=1
ENABLE_LIVE_TELEMETRY=1
LIVE_TELEMETRY_LOG_PATH=logs/crypto_forward_telemetry.jsonl
LIVE_TELEMETRY_INCLUDE_SIGNAL_DETAILS=1
ENABLE_LIVE_HEARTBEAT=1
LIVE_HEARTBEAT_PATH=logs/crypto_forward_heartbeat.json
HEALTH_MAX_SCAN_AGE_MINUTES=15
ENABLE_HEALTH_ALERTS=0
HEALTH_ALERT_STATE_PATH=logs/crypto_forward_health_alert_state.json
HEALTH_ALERT_COOLDOWN_MINUTES=60
ENABLE_FEED_HEALTH_CHECKS=1

ENABLE_FORWARD_OUTCOME_TRACKER=0
FORWARD_OUTCOME_LOG_PATH=logs/crypto_forward_outcomes.jsonl
FORWARD_OUTCOME_SUMMARY_PATH=reports/crypto_forward_outcomes_summary.json
FORWARD_OUTCOME_TIMEFRAME=M15
FORWARD_OUTCOME_HISTORY_LIMIT=1500
FORWARD_OUTCOME_SENT_ONLY=1
FORWARD_OUTCOME_MAX_HOLD_BARS=48
FORWARD_OUTCOME_ENTRY_EXPIRY_BARS=0
FORWARD_OUTCOME_AMBIGUOUS_POLICY=ambiguous

ENABLE_FORWARD_PERFORMANCE_REPORT=0
FORWARD_PERFORMANCE_REPORT_PATH=reports/crypto_forward_performance_report.json
FORWARD_PERFORMANCE_SENT_ONLY=1
FORWARD_PERFORMANCE_SCORE_BUCKET_SIZE=5
FORWARD_PERFORMANCE_MIN_CLOSED_TRADES=0
DAILY_FORWARD_REPORT_PATH=reports/crypto_forward_daily_report.json
DAILY_FORWARD_REPORT_RECENT_MINUTES=1440
DAILY_FORWARD_REPORT_SENT_ONLY=1
DAILY_FORWARD_REPORT_MIN_CLOSED_TRADES=10
DAILY_FORWARD_REPORT_SEND_TELEGRAM=0
DAILY_FORWARD_REPORT_TELEGRAM_ON_NO_SIGNALS=1

ENABLE_REALISTIC_EXECUTION=1
SPREAD_BY_PAIR=BTCUSDT:5,ETHUSDT:5
SLIPPAGE_MODE=volatility
MAX_SLIPPAGE_PIPS=10
LIMIT_TOUCH_TOLERANCE_PIPS=5
APPLY_SPREAD_TO_LIMIT=1

ENABLE_PRE_TRADE_FILTER=0
ENABLE_PRE_TRADE_FILTER_SHADOW=0
ENABLE_FEED_SAFE_MODE=0
