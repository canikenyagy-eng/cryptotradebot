# Phase 9 crypto sandbox execution architecture.
# This consumes Phase 8 dry-run intents. It does not send exchange orders.

MARKET_TYPE=crypto_spot
DATA_SOURCE=ccxt
PAIRS=BTCUSDT,ETHUSDT
ENABLE_LIVE_MODE=0

PHASE9_DRY_RUN_JSON=reports/crypto_phase8_execution_dry_run.json
PHASE9_SANDBOX_REPORT_JSON=reports/crypto_phase9_sandbox_execution_report.json
PHASE9_SANDBOX_LEDGER_CSV=reports/crypto_phase9_sandbox_order_ledger.csv
PHASE9_KILL_SWITCH_PATH=logs/crypto_execution_kill_switch.json

# dry_run or sandbox_stub. sandbox_stub is still local simulation only.
PHASE9_EXECUTION_MODE=dry_run
PHASE9_MAX_ORDERS_PER_RUN=5
PHASE9_REQUIRE_DRY_RUN_ONLY=1
PHASE9_ALLOW_SANDBOX_STUB=0

# Intentionally unsupported in Phase 9. Reports always keep live_execution_allowed=false.
PHASE9_ALLOW_LIVE_ORDERS=0
