# Phase 8 crypto execution-design dry run.
# This creates order-intent tickets only. It does not use exchange API keys or place orders.

MARKET_TYPE=crypto_spot
DATA_SOURCE=ccxt
PAIRS=BTCUSDT,ETHUSDT
ENABLE_LIVE_MODE=0

FORWARD_JOURNAL_LOG_PATH=logs/crypto_forward_journal.jsonl
PHASE8_READINESS_JSON=reports/crypto_phase7_paper_monitor.json
PHASE8_DRY_RUN_JSON=reports/crypto_phase8_execution_dry_run.json
PHASE8_ORDER_INTENTS_CSV=reports/crypto_phase8_order_intents.csv
PHASE8_DRY_RUN_DASHBOARD_HTML=reports/crypto_phase8_execution_dry_run.html

PHASE8_MAX_CANDIDATES=10
PHASE8_MIN_SCORE=0
PHASE8_ACCOUNT_EQUITY=1000
PHASE8_RISK_MODE=fixed
PHASE8_RISK_PER_INTENT=25
PHASE8_RISK_PCT=0.01
PHASE8_MIN_NOTIONAL_QUOTE=10
PHASE8_MAX_NOTIONAL_QUOTE=5000
PHASE8_MAX_RISK_QUOTE=50
PHASE8_ALLOW_SPOT_SELL=0
PHASE8_REQUIRE_PHASE7_READY=1

# Keep symbol specs explicit so dry-run sizing can validate tick and minimum size.
SYMBOL_SPECS_JSON={"BTCUSDT":{"exchange_symbol":"BTC/USDT","tick_size":0.01,"min_order_size":0.00001,"quantity_step":0.00001,"maker_fee_rate":0.001,"taker_fee_rate":0.001},"ETHUSDT":{"exchange_symbol":"ETH/USDT","tick_size":0.01,"min_order_size":0.0001,"quantity_step":0.0001,"maker_fee_rate":0.001,"taker_fee_rate":0.001}}
