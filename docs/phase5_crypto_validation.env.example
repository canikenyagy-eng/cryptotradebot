# Phase 5 crypto forward outcome tracking and validation reporting.
# This assumes Phase 4 is already writing the crypto forward journal.

MARKET_TYPE=crypto_spot
DATA_SOURCE=ccxt
CCXT_EXCHANGE_ID=binance
CCXT_DEFAULT_TYPE=spot
CCXT_OHLCV_REQUEST_LIMIT=1000

PAIRS=BTCUSDT,ETHUSDT
SYMBOL_SPECS_JSON={"BTCUSDT":{"exchange_symbol":"BTC/USDT","tick_size":0.01,"min_order_size":0.00001,"maker_fee_rate":0.001,"taker_fee_rate":0.001},"ETHUSDT":{"exchange_symbol":"ETH/USDT","tick_size":0.01,"min_order_size":0.0001,"maker_fee_rate":0.001,"taker_fee_rate":0.001}}

ENABLE_FORWARD_JOURNAL=1
FORWARD_JOURNAL_LOG_PATH=logs/crypto_forward_journal.jsonl
FORWARD_JOURNAL_INCLUDE_SCORE_BREAKDOWN=1

ENABLE_FORWARD_OUTCOME_TRACKER=1
FORWARD_OUTCOME_LOG_PATH=logs/crypto_forward_outcomes.jsonl
FORWARD_OUTCOME_SUMMARY_PATH=reports/crypto_forward_outcomes_summary.json
FORWARD_OUTCOME_TIMEFRAME=M15
FORWARD_OUTCOME_HISTORY_LIMIT=1500
FORWARD_OUTCOME_SENT_ONLY=1
FORWARD_OUTCOME_MAX_HOLD_BARS=48
FORWARD_OUTCOME_ENTRY_EXPIRY_BARS=0
FORWARD_OUTCOME_AMBIGUOUS_POLICY=ambiguous

ENABLE_FORWARD_PERFORMANCE_REPORT=1
FORWARD_PERFORMANCE_REPORT_PATH=reports/crypto_forward_performance_report.json
FORWARD_PERFORMANCE_SENT_ONLY=1
FORWARD_PERFORMANCE_SCORE_BUCKET_SIZE=5
FORWARD_PERFORMANCE_MIN_CLOSED_TRADES=30

ENABLE_LIVE_HEARTBEAT=1
LIVE_HEARTBEAT_PATH=logs/crypto_forward_heartbeat.json
HEALTH_MAX_SCAN_AGE_MINUTES=15
ENABLE_FEED_HEALTH_CHECKS=1
MARKET_DATA_DIAGNOSTICS_LOG_PATH=logs/crypto_forward_market_data.jsonl

MARKET_DATA_CACHE_ENABLED=1
MARKET_DATA_CACHE_DIR=data/cache/ohlcv
MARKET_DATA_CACHE_TTL_HOURS=0.05
MARKET_DATA_CACHE_MODE=read_through
