# Phase 13 honest as-of replay validation.
# This is historical validation only. It must not create order intents or send orders.

PHASE13_PAIRS=BTCUSDT,ETHUSDT,LTCUSDT
PHASE13_START=
PHASE13_END=
PHASE13_MAX_STEPS=96
PHASE13_HISTORY_LIMIT=1200
PHASE13_OUTCOME_TIMEFRAME=M15
PHASE13_RISK_PER_TRADE_PCT=1.0
PHASE13_REQUIRE_FULL_WARMUP=1
PHASE13_STEP_SOURCE=trigger

PHASE13_REPORT_JSON=reports/crypto_phase13_asof_replay_report.json
PHASE13_DECISIONS_JSONL=logs/crypto_phase13_asof_replay_decisions.jsonl
PHASE13_JOURNAL_JSONL=logs/crypto_phase13_asof_replay_journal.jsonl
PHASE13_OUTCOMES_JSONL=logs/crypto_phase13_asof_replay_outcomes.jsonl
PHASE13_OUTCOME_SUMMARY_JSON=reports/crypto_phase13_asof_replay_outcome_summary.json

# Optional live-vs-replay parity audit.
# PHASE13_STEP_SOURCE can be trigger, live_journal, or trigger_plus_live_journal.
PHASE13_LIVE_JOURNAL_JSONL=
PHASE13_PARITY_REPORT_JSON=reports/crypto_phase13_parity_report.json
PHASE13_MARKET_DIAGNOSTICS_JSONL=logs/crypto_forward_market_data.jsonl
